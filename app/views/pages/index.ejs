<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home - Lista Tarefas</title>
</head>

<body>
    <h1>Lista de Tarefas</h1>

    <button onclick="window.location='/nova-tarefa'">Nova tarefa</button>
    <button onclick="window.location='/mostrar-excluidas'">Mostrar Excluídas</button>
    <br><br>

    <table border="1">
        <thead>
            <tr>
                <th>ID tarefa</th>
                <th>Nome tarefa</th>
                <th>Prazo tarefa</th>
                <th>Situação tarefa</th>
                <th>Ações</th> <!-- ✅ coluna pedida -->
            </tr>
        </thead>

        <tbody>
            <% if(listaTarefas){ 
                let situacao = ["Cancelada","Pendente","Iniciada","Finalizada","Em Atraso"];

                listaTarefas.forEach((item)=>{ %>

                <tr>
                    <td><%= item.id_tarefa %></td>
                    <td><%= item.nome_tarefa %></td>
                    <td><%= moment(item.prazo_tarefa).format('L') %></td>
                    <td><%= situacao[item.situacao_tarefa] %></td>

                    <!-- ✅ coluna ações organizada -->
                    <td>
                        <% if (item.status_tarefa == 0) { %>
                            <a href="/restaurar?id=<%= item.id_tarefa %>">Restaurar</a>
                        <% } else { %>
                            <a href="/editar?id=<%= item.id_tarefa %>">Editar</a> |
                            <a href="/excluir?id=<%= item.id_tarefa %>">Excluir</a>
                        <% } %>
                    </td>
                </tr>

            <% }); 

            } else { %>

                <tr>
                    <td colspan="5">Sem tarefas para exibir</td>
                </tr>

            <% } %>
        </tbody>
    </table>

</body>

</html>